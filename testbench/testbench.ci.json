{
  "_comment": "CI config — full C+C++ benchmark suite against latest lly from RC. Every trigger runs all 8 suites end-to-end. JS/Next.js/etc. suites are intentionally excluded; see README.",
  "plugins_dir": "",
  "tests_dir": "./tests",
  "include_path": "",
  "nex": "lly",
  "lly": "lly",
  "data_dir": ".data",
  "suites": [
    {
      "id": "c-brick",
      "runner": "c-brick",
      "label": "C Brick Compilation"
    },
    {
      "id": "cpp-brick",
      "runner": "cpp-brick",
      "label": "C++ Brick Compilation"
    },
    {
      "id": "brick-format",
      "runner": "brick-format",
      "label": "Brick Format Validation"
    },
    {
      "id": "realworld-build",
      "runner": "realworld-build",
      "label": "Real-World C/C++ Programs",
      "config": {
        "timeout_ms": 600000,
        "offline_only": false
      }
    },
    {
      "id": "c-testsuite",
      "runner": "c-testsuite",
      "label": "C Testsuite (c-testsuite/c-testsuite)",
      "config": {
        "repo": "https://github.com/c-testsuite/c-testsuite",
        "data_dir": ".data/c-testsuite",
        "concurrency": 8
      }
    },
    {
      "id": "gcc-torture",
      "runner": "gcc-torture",
      "label": "GCC C Torture",
      "config": {
        "repo": "https://github.com/gcc-mirror/gcc",
        "data_dir": ".data/gcc",
        "sparse_paths": ["gcc/testsuite/gcc.c-torture"],
        "concurrency": 8
      }
    },
    {
      "id": "gcc-dg-cpp",
      "runner": "gcc-dg-cpp",
      "label": "GCC C++ Diagnostics",
      "config": {
        "repo": "https://github.com/gcc-mirror/gcc",
        "data_dir": ".data/gcc",
        "sparse_paths": ["gcc/testsuite/g++.dg"],
        "concurrency": 8
      }
    },
    {
      "id": "llvm-single",
      "runner": "llvm-single",
      "label": "LLVM single-source tests",
      "config": {
        "repo": "https://github.com/llvm/llvm-test-suite",
        "data_dir": ".data/llvm",
        "concurrency": 8
      }
    }
  ]
}
